{
  "openapi": "3.0.0",
  "info": {
    "title": "Hao Materiales ERP API 🪵",
    "version": "2.0.0",
    "description": "Sistema integral de gestión de inventarios, producción y ventas para Hao Materiales en Valledupar."
  },
  "servers": [
    {
      "url": "https://haomateriales.onrender.com",
      "description": "Servidor de Producción (Render)"
    },
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local de Desarrollo"
    }
  ],
  "tags": [
    { "name": "Autenticación", "description": "Acceso, registro y gestión de perfil" },
    { "name": "Administración", "description": "Gestión de catálogo y control global de pedidos" },
    { "name": "Clientes", "description": "Operaciones para el usuario final" },
    { "name": "Producción", "description": "Flujo de trabajo en taller" }
  ],
  "paths": {
    "/api/auth/registro": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Registrar nuevo usuario",
        "responses": { "201": { "description": "Usuario creado" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Iniciar sesión",
        "responses": { "200": { "description": "Token/Sesión generada" } }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Cerrar sesión",
        "responses": { "200": { "description": "Sesión destruida" } }
      }
    },
    "/api/auth/perfil": {
      "put": {
        "tags": ["Autenticación"],
        "summary": "Actualizar datos personales (Teléfono, Dirección, etc.)",
        "responses": { "200": { "description": "Perfil actualizado" } }
      }
    },
    "/api/admin/laminas": {
      "get": {
        "tags": ["Administración"],
        "summary": "Listar inventario de láminas",
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Administración"],
        "summary": "Crear nuevo producto",
        "responses": { "201": { "description": "Producto creado" } }
      }
    },
    "/api/admin/laminas/{id}": {
      "put": {
        "tags": ["Administración"],
        "summary": "Actualizar producto existente",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": {
        "tags": ["Administración"],
        "summary": "Eliminar producto (Borrado lógico)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Eliminado" } }
      }
    },
    "/api/usuario/pedidos": {
  "post": {
    "tags": ["Clientes"],
    "summary": "Realizar pedido vinculado al usuario y producto",
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "codigo_lamina": { "type": "string", "example": "LAM-ROBLE-01" },
              "numero_pedido": { "type": "string", "example": "FAC-5020" },
              "fecha_facturacion": { "type": "string", "example": "2026-04-12" },
              "cantidad_laminas": { "type": "integer", "example": 5 }
            }
          }
        }
      }
    },
    "responses": {
      "201": { "description": "Pedido registrado correctamente" }
    }
  }
},
    "/api/usuario/pedidos/{id}": {
      "delete": {
        "tags": ["Clientes"],
        "summary": "Cancelar un pedido (Solo si no ha iniciado producción)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Pedido cancelado" } }
      }
    },
    "/api/admin/pedidos/{id}/despachar": {
      "put": {
        "tags": ["Administración"],
        "summary": "Admin aprueba y despacha el pedido a taller",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Pedido enviado a producción" } }
      }
    },
    "/api/operador/pedidos": {
      "get": {
        "tags": ["Producción"],
        "summary": "Ver lista de pedidos en taller con filtros",
        "parameters": [
          { "name": "estado", "in": "query", "schema": { "type": "string", "enum": ["CORTE", "ENCHAPE", "REFILADA", "ZUNCHADA", "LISTO"] } }
        ],
        "responses": { "200": { "description": "Lista filtrada para el operario" } }
      }
    },
    "/api/operador/pedidos/{id}/avanzar": {
      "put": {
        "tags": ["Producción"],
        "summary": "Pasar pedido al siguiente estado (Ej: CORTE -> ENCHAPE)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Estado actualizado" } }
      }
    }
  }
}