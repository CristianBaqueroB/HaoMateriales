# MongoDB Atlas — en Atlas: Database → Connect your application → Copiar URI (mongodb+srv://...)
# Codifica caracteres especiales de la contraseña en la URL (%40 para @, etc.)
MONGO_URI=mongodb+srv://USUARIO:CONTRASENA@cluster0.xxxxx.mongodb.net/hao_materiales?retryWrites=true&w=majority&appName=NombreDelCluster

# Sesión Express
SESSION_SECRET=cambia_esto_en_produccion
PORT=3000
